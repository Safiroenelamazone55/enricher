{
  "manifest_version": 3,
  "name": "Nova Activity — Time Tracking",
  "version": "0.1.1",
  "description": "Envía a Nova el tiempo real por sitio web y pestaña activa, asociado a la tarea que estás cronometrando. Solo dominio + título + tiempo (sin contenido, sin keylogging, sin capturas).",
  "permissions": ["tabs", "idle", "storage", "alarms"],
  "host_permissions": ["https://api.kiwoc.com/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nova Activity",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
